# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Note: .terraform.lock.hcl SHOULD be committed — it pins provider versions for reproducibility

# Python virtual environment for any repo-local tooling
.venv/
