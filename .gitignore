# Claude Code
CLAUDE.md
.claude/

# Codex
AGENTS.md

# Terraform
# Local provider plugin cache and module downloads — re-created by `terraform init`
.terraform/
.terraform.tfstate.lock.info

# State files — may contain secrets, environment-specific
*.tfstate
*.tfstate.*

# Variable files — often contain secrets
*.tfvars
*.tfvars.json
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Note: .terraform.lock.hcl SHOULD be committed — it pins provider versions for reproducibility

# Python virtual environment for any repo-local tooling
.venv/

# SQL Server ISO files — too large for Git (1.5 GB+), stored in S3
*.iso

# Infrastructure baseline snapshots — excluded for PoC to avoid committing local machine config.
# In a real pipeline these should be committed so config drift is visible as a Git diff.
# Remove this entry and commit the folder when the baseline source moves to the real prod servers.
infrastructure-baseline/
